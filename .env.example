# Django
# WICHTIG: Fuer Produktion einen sicheren Key generieren:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,pm-backend

# Database — CHANGE_ME durch sichere Passwoerter ersetzen
DATABASE_URL=postgres://pmtool:CHANGE_ME@db:5432/pmtool
POSTGRES_DB=pmtool
POSTGRES_USER=pmtool
POSTGRES_PASSWORD=CHANGE_ME

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# Atlassian Cloud
ATLASSIAN_URL=https://your-domain.atlassian.net
ATLASSIAN_EMAIL=your-email@example.com
ATLASSIAN_API_TOKEN=

# Microsoft Graph (OAuth2)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_REDIRECT_URI=http://localhost:4107/api/v1/integrations/microsoft/callback/

# GitHub
GITHUB_TOKEN=

# KI-Provider: "claude", "ollama" oder "openrouter"
AI_PROVIDER=ollama

# Claude API (Anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Ollama (lokal — kein API-Key noetig)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# OpenRouter (Zugang zu vielen Modellen ueber eine API)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# KPI-Tracking (optional)
KPI_API_URL=
KPI_API_KEY=

# PM-Tool Base URL (fuer Paperclip callback_url)
PM_TOOL_BASE_URL=http://localhost:4107

# CORS / CSRF (Produktion — eigene Domain eintragen)
CORS_ALLOWED_ORIGINS=https://your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4107/api/v1
