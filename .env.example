# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://pmtool:pmtool@db:5432/pmtool
POSTGRES_DB=pmtool
POSTGRES_USER=pmtool
POSTGRES_PASSWORD=pmtool

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# Atlassian Cloud
ATLASSIAN_URL=https://your-domain.atlassian.net
ATLASSIAN_EMAIL=your-email@example.com
ATLASSIAN_API_TOKEN=your-api-token

# Microsoft Graph (OAuth2)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_REDIRECT_URI=http://localhost:4107/api/v1/integrations/microsoft/callback/

# GitHub
GITHUB_TOKEN=

# KI-Provider: "claude", "ollama" oder "openrouter"
AI_PROVIDER=claude

# Claude API (Anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Ollama (lokal — kein API-Key noetig)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# OpenRouter (Zugang zu vielen Modellen ueber eine API)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4107/api/v1
